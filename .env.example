# Required
GROQ_API_KEY=your_groq_api_key_here

# Storage
LANCE_PERSIST_DIR=./lance_db

# Models (defaults are good, change only if needed)
LLM_MODEL=llama-3.3-70b-versatile
FAST_MODEL=llama-3.1-8b-instant

# Swarm tuning
SWARM_MAX_WORKERS=3
SWARM_MAX_NEGOTIATION_ROUNDS=3
MAX_RESEARCH_ITERATIONS=2
MAX_CRITIQUE_REVISIONS=2
COHERENCE_THRESHOLD=0.75

# Visualization (disabled for this build)
SWARM_ENABLE_VISUALIZATION=0

# Skip cross-encoder re-ranker (saves RAM; uses vector search order only).
# Use on Windows if you see: OSError paging file too small (1455).
# SWARMIQ_DISABLE_RERANK=1

# Rate limiting (Groq free tier defaults)
GROQ_RPM_LIMIT=25
GROQ_TPM_LIMIT=10000

# Search
DDG_MAX_RESULTS=10
JINA_TIMEOUT_S=20
SEARCH_CACHE_TTL_HOURS=24
# Seconds between each URL fetch (lower = faster; 0 = no delay)
SEARCH_POLITE_DELAY_S=0.15
